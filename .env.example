# Database (PostgreSQL connection string)
# Example (local): postgresql://postgres:postgres@localhost:5432/freshers_portal
# Example (Neon/Supabase/Vercel Postgres): use the connection string they provide
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/freshers_portal"

# NextAuth
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (create credentials at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=""

# Weather (Open-Meteo requires no key, but OpenWeatherMap is supported as an alternative)
# Leave blank to use the free Open-Meteo API (no key required)
OPENWEATHER_API_KEY=""

# Default campus location (used by the weather widget)
CAMPUS_LAT="13.0827"
CAMPUS_LON="80.2707"
CAMPUS_NAME="Campus"
